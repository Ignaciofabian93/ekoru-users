// ─── Enums ───────────────────────────────────────────────────────────────────────

enum ContactMethod {
  EMAIL
  WHATSAPP
  PHONE
  INSTAGRAM
  FACEBOOK
  WEBSITE
  TIKTOK
}

enum SellerType {
  PERSON
  STARTUP
  COMPANY
}

enum Language {
  ES
  EN
  FR
  PT
  DE
}

enum BusinessType {
  RETAIL
  SERVICES
  MIXED
}

enum BanReason {
  FRAUD
  SCAM
  PAYMENT_ABUSE
  COUNTERFEIT
  PROHIBITED_ITEMS
  HARASSMENT
  SPAM
  MULTIPLE_ACCOUNTS
  POLICY_VIOLATION
  CHARGEBACK_ABUSE
  OTHER
}

enum TransactionKind {
  PURCHASE
  SELL
  STOREPURCHASE
  EXCHANGE
  RECYCLE
  REPAIR
  ATTENDTOWORKSHOP
  ATTENDTOEVENT
  REGISTRATION
  BONUS
}

enum PersonSubscriptionPlan {
  FREEMIUM
  BASIC
  ADVANCED
}

enum BusinessSubscriptionPlan {
  FREEMIUM
  STARTUP
  BASIC
  ADVANCED
  EXPERT
}

enum AdminType {
  PLATFORM
  BUSINESS
}

enum AdminRole {
  SUPER_ADMIN
  MODERATOR
  CONTENT_MANAGER
  SUPPORT
  BUSINESS_OWNER
  BUSINESS_MANAGER
  BUSINESS_ANALYST
  BUSINESS_SUPPORT
}

enum AdminPermission {
  MANAGE_PRODUCTS
  APPROVE_PRODUCTS
  DELETE_PRODUCTS
  WRITE_BLOG
  PUBLISH_BLOG
  DELETE_BLOG
  MODERATE_CONTENT
  MANAGE_USERS
  BAN_USERS
  VIEW_USER_DATA
  MANAGE_ORDERS
  PROCESS_REFUNDS
  VIEW_TRANSACTIONS
  VIEW_ANALYTICS
  EXPORT_DATA
  MANAGE_ADMINS
  MANAGE_CATEGORIES
  MANAGE_SETTINGS
  VIEW_SYSTEM_LOGS
  MANAGE_BUSINESS_PROFILE
  MANAGE_BUSINESS_TEAM
  VIEW_BUSINESS_ANALYTICS
  MANAGE_BUSINESS_PRODUCTS
  MANAGE_BUSINESS_ORDERS
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  ORDER_RECEIVED
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  QUOTATION_REQUEST
  QUOTATION_RECEIVED
  QUOTATION_ACCEPTED
  QUOTATION_DECLINED
  EXCHANGE_PROPOSAL
  EXCHANGE_ACCEPTED
  EXCHANGE_DECLINED
  EXCHANGE_COMPLETED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  REVIEW_RECEIVED
  MESSAGE_RECEIVED
  PRODUCT_LIKED
  PRODUCT_COMMENTED
  SYSTEM_ANNOUNCEMENT
  ACCOUNT_VERIFICATION
  PROFILE_UPDATED
}

// ─── Models ──────────────────────────────────────────────────────────────────────

model Seller {
  id                                               String                      @id @default(uuid())
  email                                            String                      @unique
  password                                         String
  sellerType                                       SellerType
  isActive                                         Boolean                     @default(true)
  isVerified                                       Boolean                     @default(false)
  createdAt                                        DateTime                    @default(now())
  updatedAt                                        DateTime                    @updatedAt
  address                                          String?
  cityId                                           Int?
  countryId                                        Int?
  countyId                                         Int?
  regionId                                         Int?
  phone                                            String?
  website                                          String?
  preferredContactMethod                           ContactMethod?              @default(WHATSAPP)
  socialMediaLinks                                 Json?
  points                                           Int                         @default(0)
  sellerLevelId                                    Int?
  admin                                            Admin[]
  businessProfile                                  BusinessProfile?
  match_Match_receiverIdToSeller                   Match[]                     @relation("Match_receiverIdToSeller")
  match_Match_senderIdToSeller                     Match[]                     @relation("Match_senderIdToSeller")
  notification                                     Notification[]
  personProfile                                    PersonProfile?
  city                                             City?                       @relation(fields: [cityId], references: [id])
  country                                          Country?                    @relation(fields: [countryId], references: [id])
  county                                           County?                     @relation(fields: [countyId], references: [id])
  region                                           Region?                     @relation(fields: [regionId], references: [id])
  sellerLevel                                      SellerLevel?                @relation(fields: [sellerLevelId], references: [id])
  achievedLabels                                   SellerAchievedLabel[]
  sellerPreferences                                SellerPreferences?
  personMembershipSubscription                     PersonMembershipSubscription[]
  businessMembershipSubscription                   BusinessMembershipSubscription[]
  bans                                             BannedSeller[]

  @@index([cityId])
  @@index([email])
  @@index([isActive])
  @@index([isVerified])
  @@index([sellerType])
  @@index([sellerType, isActive])
  @@index([sellerLevelId])
  @@index([points(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model SellerPreferences {
  id                 Int     @id @default(autoincrement())
  sellerId           String  @unique
  preferredLanguage  String? @default("es")
  currency           String? @default("CLP")
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  orderUpdates       Boolean @default(true)
  communityUpdates   Boolean @default(true)
  securityAlerts     Boolean @default(true)
  weeklySummary      Boolean @default(false)
  twoFactorAuth      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  seller             Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model PersonProfile {
  id                 String            @id @default(uuid())
  sellerId           String            @unique
  firstName          String
  lastName           String?
  displayName        String?
  bio                String?
  birthday           DateTime?
  profileImage       String?
  coverImage         String?
  allowExchanges     Boolean           @default(true)
  personMembershipSubscriptionId Int?
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
  personMembershipSubscription   PersonMembershipSubscription?  @relation(fields: [personMembershipSubscriptionId], references: [id])
  seller                         Seller                         @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([personMembershipSubscriptionId])
  @@index([sellerId])
}

model BusinessProfile {
  id                       String              @id @default(uuid())
  sellerId                 String              @unique
  businessName             String
  description              String?
  logo                     String?
  coverImage               String?
  businessType             BusinessType
  legalBusinessName        String?
  taxId                    String?             @unique
  businessStartDate        DateTime?
  legalRepresentative      String?
  legalRepresentativeTaxId String?
  shippingPolicy           String?
  returnPolicy             String?
  serviceArea              String?
  yearsOfExperience        Int?
  certifications           String[]
  travelRadius             Int?
  businessHours            Json?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  businessMembershipSubscriptionId Int?
  businessMembershipSubscription   BusinessMembershipSubscription? @relation(fields: [businessMembershipSubscriptionId], references: [id])
  seller                           Seller                          @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([taxId])
  @@index([businessType])
  @@index([businessMembershipSubscriptionId])
  @@index([sellerId])
}

model BannedSeller {
  id           String    @id @default(uuid())
  sellerId     String
  reasonCode   BanReason  @default(OTHER)
  reason       String // Human-written explanation shown in moderation tooling
  notes        String? // Internal-only admin notes
  evidence     Json? // Links / screenshots / snapshot of obligations at ban time
  bannedById   String // Admin who issued the ban
  bannedAt     DateTime  @default(now())
  expiresAt    DateTime? // null = permanent ban
  isActive     Boolean   @default(true) // true = currently enforced
  unbannedAt   DateTime?
  unbannedById String? // Admin who lifted the ban
  unbanReason  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  seller       Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  bannedBy     Admin     @relation("BansIssued", fields: [bannedById], references: [id])
  unbannedBy   Admin?    @relation("BansLifted", fields: [unbannedById], references: [id])

  @@index([sellerId])
  @@index([sellerId, isActive])
  @@index([isActive])
  @@index([bannedById])
  @@index([expiresAt])
}

model SellerLabel {
  id                   Int                        @id @default(autoincrement())
  labelName            String                     @unique
  transactionKind      TransactionKind
  transactionsRequired Int
  description          String?
  badgeIcon            String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  achievedBy           SellerAchievedLabel[]
  translations         SellerLabelTranslation[]

  @@index([transactionKind])
  @@index([transactionsRequired])
}

model SellerLabelTranslation {
  id            Int         @id @default(autoincrement())
  sellerLabelId Int
  language      Language
  labelName     String
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  sellerLabel   SellerLabel @relation(fields: [sellerLabelId], references: [id], onDelete: Cascade)

  @@unique([sellerLabelId, language])
  @@index([language])
}

model SellerAchievedLabel {
  id           Int         @id @default(autoincrement())
  sellerId     String
  labelId      Int
  achievedAt   DateTime    @default(now())
  currentCount Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  label        SellerLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  seller       Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, labelId])
  @@index([sellerId])
  @@index([labelId])
  @@index([achievedAt])
}

model SellerLevel {
  id           Int                        @id @default(autoincrement())
  levelName    String                     @unique
  minPoints    Int                        @unique
  maxPoints    Int?
  benefits     Json?
  badgeIcon    String?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  sellers      Seller[]
  translations SellerLevelTranslation[]

  @@index([minPoints])
}

model SellerLevelTranslation {
  id            Int         @id @default(autoincrement())
  sellerLevelId Int
  language      Language
  levelName     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  sellerLevel   SellerLevel @relation(fields: [sellerLevelId], references: [id], onDelete: Cascade)

  @@unique([sellerLevelId, language])
  @@index([language])
}

model PointsByTransactionKind {
  id              Int             @id @default(autoincrement())
  transactionKind TransactionKind @unique
  pointsAwarded   Int
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([transactionKind])
}

model PersonMembership {
  id             Int                            @id @default(autoincrement())
  membershipType PersonSubscriptionPlan         @default(FREEMIUM)
  durationMonths Int
  isActive       Boolean                        @default(true)
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  subscriptions  PersonMembershipSubscription[]
  translations   PersonMembershipTranslation[]
  pricing        PersonMembershipPricing[]

  @@index([membershipType])
  @@index([isActive])
}

model PersonMembershipTranslation {
  id                 Int              @id @default(autoincrement())
  personMembershipId Int
  language           Language
  name               String
  description        String[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  personMembership   PersonMembership @relation(fields: [personMembershipId], references: [id], onDelete: Cascade)

  @@unique([personMembershipId, language])
  @@index([language, personMembershipId])
}

model PersonMembershipPricing {
  id                 Int              @id @default(autoincrement())
  personMembershipId Int
  countryId          Int
  currency           String
  price              Float
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  personMembership   PersonMembership @relation(fields: [personMembershipId], references: [id], onDelete: Cascade)
  country            Country          @relation(fields: [countryId], references: [id])

  @@unique([personMembershipId, countryId])
  @@index([personMembershipId])
  @@index([countryId])
}

model PersonMembershipSubscription {
  id                 Int              @id @default(autoincrement())
  sellerId           String
  personMembershipId Int
  startDate          DateTime         @default(now())
  endDate            DateTime?
  isActive           Boolean          @default(true)
  autoRenew          Boolean          @default(false)
  paymentId          Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  personMembership   PersonMembership @relation(fields: [personMembershipId], references: [id])
  seller             Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  personProfiles     PersonProfile[]

  @@index([sellerId])
  @@index([personMembershipId])
  @@index([isActive])
  @@index([endDate])
}

model BusinessMembership {
  id               Int                               @id @default(autoincrement())
  membershipType   BusinessSubscriptionPlan          @default(FREEMIUM)
  durationMonths   Int
  isActive         Boolean                           @default(true)
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  subscriptions    BusinessMembershipSubscription[]
  translations     BusinessMembershipTranslation[]
  pricing          BusinessMembershipPricing[]

  @@index([membershipType])
  @@index([isActive])
}

model BusinessMembershipTranslation {
  id                   Int                @id @default(autoincrement())
  businessMembershipId Int
  language             Language
  name                 String
  description          String[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  businessMembership   BusinessMembership @relation(fields: [businessMembershipId], references: [id], onDelete: Cascade)

  @@unique([businessMembershipId, language])
  @@index([language, businessMembershipId])
}

model BusinessMembershipPricing {
  id                   Int                @id @default(autoincrement())
  businessMembershipId Int
  countryId            Int
  currency             String
  price                Float
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  businessMembership   BusinessMembership @relation(fields: [businessMembershipId], references: [id], onDelete: Cascade)
  country              Country            @relation(fields: [countryId], references: [id])

  @@unique([businessMembershipId, countryId])
  @@index([businessMembershipId])
  @@index([countryId])
}

model BusinessMembershipSubscription {
  id                   Int                @id @default(autoincrement())
  sellerId             String
  businessMembershipId Int
  startDate            DateTime           @default(now())
  endDate              DateTime?
  isActive             Boolean            @default(true)
  autoRenew            Boolean            @default(false)
  paymentId            Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  businessMembership   BusinessMembership @relation(fields: [businessMembershipId], references: [id])
  seller               Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  businessProfiles     BusinessProfile[]

  @@index([sellerId])
  @@index([businessMembershipId])
  @@index([isActive])
  @@index([endDate])
}

model Admin {
  id               String             @id @default(uuid())
  email            String             @unique
  password         String
  name             String
  lastName         String?
  adminType        AdminType          @default(PLATFORM)
  role             AdminRole          @default(MODERATOR)
  permissions      AdminPermission[]
  sellerId         String?
  isActive         Boolean            @default(true)
  isEmailVerified  Boolean            @default(false)
  accountLocked    Boolean            @default(false)
  loginAttempts    Int                @default(0)
  lastLoginAt      DateTime?
  lastLoginIp      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  cityId           Int?
  countryId        Int?
  countyId         Int?
  regionId         Int?
  city             City?              @relation(fields: [cityId], references: [id])
  country          Country?           @relation(fields: [countryId], references: [id])
  county           County?            @relation(fields: [countyId], references: [id])
  region           Region?            @relation(fields: [regionId], references: [id])
  seller           Seller?            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  adminActivityLog     AdminActivityLog[]
  bansIssued           BannedSeller[]     @relation("BansIssued")
  bansLifted           BannedSeller[]     @relation("BansLifted")

  @@index([email])
  @@index([sellerId])
  @@index([adminType])
  @@index([isActive])
}

model AdminActivityLog {
  id         Int      @id @default(autoincrement())
  adminId    String
  action     String
  entityType String?
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([adminId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([action, createdAt(sort: Desc)])
}

model Country {
  id                      Int                       @id @default(autoincrement())
  // ISO 3166-1 alpha-2 code (e.g. "CL", "CA"). Lets the search subgraph scope a
  // guest's results to their selected country. Nullable for backfill; populate
  // existing rows then consider making it required.
  code                    String?                   @unique
  translation             CountryTranslation[]
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  admin                   Admin[]
  region                  Region[]
  seller                  Seller[]
  personMembershipPricing PersonMembershipPricing[]
  businessMembershipPricing BusinessMembershipPricing[]
}

model CountryTranslation {
  id        Int      @id @default(autoincrement())
  countryId Int
  language  Language
  name      String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@index([language])
  @@index([countryId])
}

model Region {
  id              Int               @id @default(autoincrement())
  region          String
  countryId       Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  admin           Admin[]
  city            City[]
  country         Country           @relation(fields: [countryId], references: [id])
  seller          Seller[]
}

model City {
  id              Int               @id @default(autoincrement())
  city            String
  regionId        Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  admin           Admin[]
  region          Region            @relation(fields: [regionId], references: [id])
  county          County[]
  seller          Seller[]
}

model County {
  id              Int               @id @default(autoincrement())
  county          String
  cityId          Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  admin           Admin[]
  city            City              @relation(fields: [cityId], references: [id])
  seller          Seller[]
}

model Notification {
  id        Int                  @id @default(autoincrement())
  sellerId  String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean              @default(false)
  priority  NotificationPriority @default(MEDIUM)
  relatedId String?
  actionUrl String?
  metadata  Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  readAt    DateTime?
  seller    Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([isRead])
  @@index([sellerId])
  @@index([type])
}

model NotificationTemplate {
  id           Int                               @id @default(autoincrement())
  type         NotificationType                  @unique
  title        String
  message      String
  isActive     Boolean                           @default(true)
  createdAt    DateTime                          @default(now())
  updatedAt    DateTime                          @updatedAt
  translations NotificationTemplateTranslation[]

  @@index([type])
}

model NotificationTemplateTranslation {
  id                     Int                  @id @default(autoincrement())
  notificationTemplateId Int
  language               Language
  title                  String
  message                String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  notificationTemplate   NotificationTemplate @relation(fields: [notificationTemplateId], references: [id], onDelete: Cascade)

  @@unique([notificationTemplateId, language])
  @@index([language])
}

model Match {
  id                              Int      @id @default(autoincrement())
  senderId                        String
  receiverId                      String
  createdAt                       DateTime @default(now())
  isMatched                       Boolean  @default(false)
  updatedAt                       DateTime @updatedAt
  seller_Match_receiverIdToSeller Seller   @relation("Match_receiverIdToSeller", fields: [receiverId], references: [id])
  seller_Match_senderIdToSeller   Seller   @relation("Match_senderIdToSeller", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([isMatched])
}

